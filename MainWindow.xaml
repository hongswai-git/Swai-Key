<Window x:Class="WpfKeyAutoClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Swai Key"
        Width="430"
        Height="650"
        MinWidth="430"
        MinHeight="650"
        MaxWidth="430"
        MaxHeight="650"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Icon="assets/app.ico"
        Background="Transparent"
        FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei UI">
  <Window.Resources>
    <SolidColorBrush x:Key="AppBg" Color="#0D1021" />
    <SolidColorBrush x:Key="PanelBg" Color="#111827" />
    <SolidColorBrush x:Key="CardBg" Color="#151A2D" />
    <SolidColorBrush x:Key="CardHi" Color="#1B2140" />
    <SolidColorBrush x:Key="Stroke" Color="#2D2A68" />
    <SolidColorBrush x:Key="StrokeHot" Color="#4B3BCB" />
    <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC" />
    <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8" />
    <SolidColorBrush x:Key="Cyan" Color="#22D3EE" />
    <SolidColorBrush x:Key="Purple" Color="#8B5CF6" />
    <SolidColorBrush x:Key="Pink" Color="#EC4899" />
    <SolidColorBrush x:Key="Yellow" Color="#FACC15" />
    <SolidColorBrush x:Key="Green" Color="#10B981" />

    <LinearGradientBrush x:Key="TitleGradient" StartPoint="0,0" EndPoint="0,1">
      <GradientStop Color="#FFFFFF" Offset="0" />
      <GradientStop Color="#FFFFFF" Offset="0.58" />
      <GradientStop Color="#22D3EE" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ActionGradient" StartPoint="0,0" EndPoint="1,0">
      <GradientStop Color="#22D3EE" Offset="0" />
      <GradientStop Color="#5B7CFF" Offset="0.58" />
      <GradientStop Color="#EC4899" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#171D39" Offset="0" />
      <GradientStop Color="#0F1430" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="TitleButton" TargetType="{x:Type Button}">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="#141A36" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="#302A76" BorderThickness="2" CornerRadius="3">
              <Grid>
                <Border Height="4" VerticalAlignment="Top" Margin="4,2,4,0" Background="#2D2A68" />
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Cyan}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Opacity" Value="0.78" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="{x:Type Button}">
      <Setter Property="Height" Value="48" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="Black" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="Outer" CornerRadius="8" Background="#0A0E23" BorderBrush="#5B48F2" BorderThickness="2" SnapsToDevicePixels="True">
              <Border Margin="4" CornerRadius="5" Background="{StaticResource ActionGradient}" BorderBrush="#5B48F2" BorderThickness="1" SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Outer" Property="BorderBrush" Value="{StaticResource Pink}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Outer" Property="Opacity" Value="0.82" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PixelTextBox" TargetType="{x:Type TextBox}">
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
      <Setter Property="CaretBrush" Value="{StaticResource Cyan}" />
      <Setter Property="Background" Value="#0F1430" />
      <Setter Property="BorderBrush" Value="#2D2A68" />
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type TextBox}">
            <Border x:Name="Root" CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
              <Grid>
                <Border Height="3" VerticalAlignment="Top" Margin="5,4,5,0" Background="#1D2550" />
                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Cyan}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SwaiCheckBox" TargetType="{x:Type CheckBox}">
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type CheckBox}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Border x:Name="Box" Width="22" Height="22" CornerRadius="4" Background="#101633" BorderBrush="#313071" BorderThickness="2">
                <Grid>
                  <Rectangle x:Name="Glow" Width="10" Height="10" Fill="{StaticResource Cyan}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />
                </Grid>
              </Border>
              <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Cyan}" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Pink}" />
                <Setter TargetName="Glow" Property="Visibility" Value="Visible" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="IconCell" TargetType="{x:Type Border}">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="BorderBrush" Value="#201B58" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
  </Window.Resources>

  <Border Margin="14" CornerRadius="12" Background="{StaticResource AppBg}" BorderBrush="#3B2EA3" BorderThickness="2" SnapsToDevicePixels="True">
    <Border.Effect>
      <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.22" Color="#7C3AED" />
    </Border.Effect>
    <Grid ClipToBounds="True" SnapsToDevicePixels="True">
      <Grid.RowDefinitions>
        <RowDefinition Height="54" />
        <RowDefinition Height="*" />
        <RowDefinition Height="38" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="#0B1028" BorderBrush="#1D2255" BorderThickness="0,0,0,2" PreviewMouseLeftButtonDown="TitleBar_PreviewMouseLeftButtonDown">
        <Grid>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
            <Border Width="30" Height="30" CornerRadius="4" Background="#1B1452" BorderBrush="#302A76" BorderThickness="2" ClipToBounds="True">
              <Image Source="assets/swai-key.png" Stretch="UniformToFill" />
            </Border>
            <TextBlock Text="Swai Key" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
            <Button Style="{StaticResource TitleButton}" Click="MinimizeButton_Click">
              <Path Width="16" Height="3" Stretch="Fill" Fill="{StaticResource TextPrimary}" Data="M0,0 L18,0 L18,4 L0,4 Z" />
            </Button>
            <Button Margin="8,0,0,0" Style="{StaticResource TitleButton}" Background="#D8424D" Click="CloseButton_Click">
              <Grid Width="18" Height="18">
                <Path Stroke="White" StrokeThickness="4" StrokeStartLineCap="Square" StrokeEndLineCap="Square" Data="M3,3 L15,15" />
                <Path Stroke="White" StrokeThickness="4" StrokeStartLineCap="Square" StrokeEndLineCap="Square" Data="M15,3 L3,15" />
              </Grid>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="1" Margin="16,14,16,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="110" />
          <RowDefinition Height="178" />
          <RowDefinition Height="104" />
          <RowDefinition Height="60" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
          <StackPanel VerticalAlignment="Center">
            <Grid Width="220" Height="48" HorizontalAlignment="Left">
              <TextBlock Text="Swai Key" Margin="3,3,0,0" Foreground="#163B70" FontSize="38" FontWeight="Black" />
              <TextBlock Text="Swai Key" Foreground="{StaticResource TitleGradient}" FontSize="38" FontWeight="Black" />
            </Grid>
            <TextBlock x:Name="SubtitleText" Margin="2,8,0,0" Foreground="{StaticResource Cyan}" FontSize="15" FontWeight="SemiBold" Text="小体积、无广告。F7 启动或停止。" />
          </StackPanel>

          <Grid Width="100" Height="90" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0">
            <Border Width="62" Height="62" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="8" Background="#8B5CF6" BorderBrush="#F7E7FF" BorderThickness="3" RenderTransformOrigin="0.5,0.5">
              <Border.RenderTransform>
                <TransformGroup>
                  <RotateTransform Angle="10" />
                  <SkewTransform AngleX="-8" />
                </TransformGroup>
              </Border.RenderTransform>
              <TextBlock Text="F7" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="24" FontWeight="Black" />
            </Border>
            <TextBlock Text="+" Foreground="{StaticResource Yellow}" FontSize="22" FontWeight="Black" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4,8,0,0" />
            <TextBlock Text="+" Foreground="{StaticResource Cyan}" FontSize="18" FontWeight="Black" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,12" />
            <TextBlock Text="+" Foreground="{StaticResource Pink}" FontSize="20" FontWeight="Black" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,22,2,0" />
          </Grid>
        </Grid>

        <Border Grid.Row="1" Padding="14" CornerRadius="8" Background="{StaticResource CardGradient}" BorderBrush="{StaticResource StrokeHot}" BorderThickness="2">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="48" />
              <RowDefinition Height="2" />
              <RowDefinition Height="50" />
              <RowDefinition Height="2" />
              <RowDefinition Height="48" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="138" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Border Style="{StaticResource IconCell}" Background="#3B82F6">
                <UniformGrid Rows="3" Columns="3" Margin="6">
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                </UniformGrid>
              </Border>
              <TextBlock x:Name="KeyLabel" Text="连点键位" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Bold" />
            </StackPanel>
            <TextBox x:Name="KeyBox" Grid.Column="1" Text="Space" TextAlignment="Center" IsReadOnly="True" Style="{StaticResource PixelTextBox}" PreviewKeyDown="KeyBox_PreviewKeyDown" />

            <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#1F2354" Margin="0,0,0,0" />

            <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
              <Border Style="{StaticResource IconCell}" Background="#5AE136">
                <Grid Margin="6">
                  <Rectangle Width="7" Height="7" Fill="#101633" HorizontalAlignment="Center" VerticalAlignment="Top" />
                  <Rectangle Width="7" Height="7" Fill="#101633" HorizontalAlignment="Left" VerticalAlignment="Bottom" />
                  <Rectangle Width="7" Height="7" Fill="#101633" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
                </Grid>
              </Border>
              <TextBlock x:Name="ModifiersLabel" Text="组合按键" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Bold" />
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
              <CheckBox x:Name="CtrlBox" Content="Ctrl" Margin="0,0,10,0" Style="{StaticResource SwaiCheckBox}" />
              <CheckBox x:Name="ShiftBox" Content="Shift" Margin="0,0,10,0" Style="{StaticResource SwaiCheckBox}" />
              <CheckBox x:Name="AltBox" Content="Alt" Style="{StaticResource SwaiCheckBox}" />
            </StackPanel>

            <Border Grid.Row="3" Grid.ColumnSpan="2" Background="#1F2354" />

            <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center">
              <Border Style="{StaticResource IconCell}" Background="#EC4899">
                <Grid>
                  <Ellipse Stroke="#101633" StrokeThickness="4" Margin="6" />
                  <Rectangle Width="4" Height="10" Fill="#101633" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,6,0,0" />
                </Grid>
              </Border>
              <TextBlock x:Name="IntervalLabel" Text="按键间隔" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Bold" />
            </StackPanel>
            <Grid Grid.Row="4" Grid.Column="1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="38" />
              </Grid.ColumnDefinitions>
              <TextBox x:Name="IntervalBox" Text="100" TextAlignment="Center" Style="{StaticResource PixelTextBox}" PreviewTextInput="IntervalBox_PreviewTextInput" LostFocus="IntervalBox_LostFocus" KeyDown="IntervalBox_KeyDown" />
              <TextBlock Grid.Column="1" Text="ms" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Purple}" FontSize="17" FontWeight="Bold" />
            </Grid>
          </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,14,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Padding="14,12" CornerRadius="8" Background="{StaticResource CardGradient}" BorderBrush="{StaticResource StrokeHot}" BorderThickness="2">
            <StackPanel>
              <TextBlock x:Name="StatusLabel" Text="状态" Foreground="{StaticResource Purple}" FontSize="16" FontWeight="Bold" />
              <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="♥" Foreground="{StaticResource Pink}" FontSize="22" FontWeight="Black" VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText" Text="已停止" Margin="14,0,0,0" Foreground="{StaticResource Cyan}" FontSize="24" FontWeight="Black" VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Text=". . . . . ." Foreground="{StaticResource Purple}" FontSize="17" Opacity="0.8" />
            </StackPanel>
          </Border>

          <Border Grid.Column="2" Padding="14,12" CornerRadius="8" Background="{StaticResource CardGradient}" BorderBrush="{StaticResource StrokeHot}" BorderThickness="2">
            <StackPanel>
              <TextBlock x:Name="CountLabel" Text="按键次数" Foreground="{StaticResource Purple}" FontSize="16" FontWeight="Bold" />
              <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="★" Foreground="{StaticResource Yellow}" FontSize="22" FontWeight="Black" VerticalAlignment="Center" />
                <TextBlock x:Name="CountText" Text="0" Margin="14,0,0,0" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Black" VerticalAlignment="Center" />
                <TextBlock x:Name="CountUnitText" Text="次" Margin="12,0,0,2" Foreground="{StaticResource TextPrimary}" FontSize="14" VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Text=". . . . . ." Foreground="{StaticResource Purple}" FontSize="17" Opacity="0.8" />
            </StackPanel>
          </Border>
        </Grid>

        <Button x:Name="ToggleButton" Grid.Row="3" Margin="4,8,4,0" Content=">> 开始 F7" Style="{StaticResource PrimaryButton}" Click="ToggleButton_Click" />

        <Grid Grid.Row="4" Margin="0,10,0,0">
          <Border Height="44" VerticalAlignment="Top" CornerRadius="8" Background="#111735" BorderBrush="{StaticResource Stroke}" BorderThickness="2">
            <Grid>
              <CheckBox x:Name="TopmostBox" Margin="16,0,0,0" Content="窗口置顶" VerticalAlignment="Center" HorizontalAlignment="Left" Style="{StaticResource SwaiCheckBox}" Checked="TopmostBox_Changed" Unchecked="TopmostBox_Changed" />
            </Grid>
          </Border>
        </Grid>
      </Grid>

      <Border Grid.Row="2" Background="#0A0E23" BorderBrush="#202557" BorderThickness="0,2,0,0">
        <TextBlock x:Name="FooterText" Text="♥  Designed by Hongswai · 中文  ♥" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Purple}" FontSize="13" FontWeight="Bold" Cursor="Hand" MouseLeftButtonUp="FooterText_MouseLeftButtonUp" />
      </Border>
    </Grid>
  </Border>
</Window>

