<Window x:Class="WpfKeyAutoClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Swai Key"
        Width="430"
        Height="650"
        MinWidth="430"
        MinHeight="650"
        MaxWidth="430"
        MaxHeight="650"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Icon="assets/app.ico"
        Background="Transparent"
        FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei UI">
  <Window.Resources>
    <SolidColorBrush x:Key="AppBg" Color="#0D1021" />
    <SolidColorBrush x:Key="PanelBg" Color="#111827" />
    <SolidColorBrush x:Key="CardBg" Color="#151A2D" />
    <SolidColorBrush x:Key="CardHi" Color="#1B2140" />
    <SolidColorBrush x:Key="Stroke" Color="#2D2A68" />
    <SolidColorBrush x:Key="StrokeHot" Color="#4B3BCB" />
    <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC" />
    <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8" />
    <SolidColorBrush x:Key="Cyan" Color="#22D3EE" />
    <SolidColorBrush x:Key="Purple" Color="#8B5CF6" />
    <SolidColorBrush x:Key="Pink" Color="#EC4899" />
    <SolidColorBrush x:Key="Yellow" Color="#FACC15" />
    <SolidColorBrush x:Key="Green" Color="#10B981" />

    <LinearGradientBrush x:Key="TitleGradient" StartPoint="0,0" EndPoint="0,1">
      <GradientStop Color="#FFFFFF" Offset="0" />
      <GradientStop Color="#FFFFFF" Offset="0.58" />
      <GradientStop Color="#22D3EE" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ActionGradient" StartPoint="0,0" EndPoint="1,0">
      <GradientStop Color="#22D3EE" Offset="0" />
      <GradientStop Color="#5B7CFF" Offset="0.58" />
      <GradientStop Color="#EC4899" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#171D39" Offset="0" />
      <GradientStop Color="#0F1430" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="TitleButton" TargetType="{x:Type Button}">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="#141A36" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="#302A76" BorderThickness="2" CornerRadius="3">
              <Grid>
                <Border Height="4" VerticalAlignment="Top" Margin="4,2,4,0" Background="#2D2A68" />
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Cyan}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Opacity" Value="0.78" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="{x:Type Button}">
      <Setter Property="Height" Value="44" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="Black" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Grid>
              <Border x:Name="HoverGlow" CornerRadius="8" BorderBrush="{StaticResource Cyan}" BorderThickness="2" Opacity="0">
                <Border.Effect>
                  <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.8" Color="#22D3EE" />
                </Border.Effect>
              </Border>
              <Border x:Name="Outer" CornerRadius="8" Background="#0A0E23" BorderBrush="#5B48F2" BorderThickness="2" SnapsToDevicePixels="True">
                <Border Margin="4" CornerRadius="5" Background="{StaticResource ActionGradient}" BorderBrush="#5B48F2" BorderThickness="1" SnapsToDevicePixels="True">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </Border>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Outer" Property="BorderBrush" Value="{StaticResource Pink}" />
                <Setter TargetName="HoverGlow" Property="Opacity" Value="0.55" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Outer" Property="Opacity" Value="0.82" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PixelTextBox" TargetType="{x:Type TextBox}">
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
      <Setter Property="CaretBrush" Value="{StaticResource Cyan}" />
      <Setter Property="Background" Value="#0F1430" />
      <Setter Property="BorderBrush" Value="#2D2A68" />
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type TextBox}">
            <Border x:Name="Root" CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
              <Grid>
                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Cyan}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SwaiCheckBox" TargetType="{x:Type CheckBox}">
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type CheckBox}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Border x:Name="Box" Width="20" Height="20" CornerRadius="4" Background="#101633" BorderBrush="#313071" BorderThickness="2">
                <Grid>
                  <Rectangle x:Name="Glow" Width="10" Height="10" Fill="{StaticResource Cyan}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />
                </Grid>
              </Border>
              <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Cyan}" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Pink}" />
                <Setter TargetName="Glow" Property="Visibility" Value="Visible" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="IconCell" TargetType="{x:Type Border}">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="24" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="BorderBrush" Value="#201B58" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
  </Window.Resources>

  <Border Margin="14" CornerRadius="12" Background="{StaticResource AppBg}" BorderBrush="#3B2EA3" BorderThickness="2" SnapsToDevicePixels="True">
    <Border.Effect>
      <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.22" Color="#7C3AED" />
    </Border.Effect>
    <Grid ClipToBounds="True" SnapsToDevicePixels="True">
      <Grid.RowDefinitions>
        <RowDefinition Height="54" />
        <RowDefinition Height="*" />
        <RowDefinition Height="38" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="#0B1028" BorderBrush="#1D2255" BorderThickness="0,0,0,2" PreviewMouseLeftButtonDown="TitleBar_PreviewMouseLeftButtonDown">
        <Grid>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
            <Border Width="30" Height="30" CornerRadius="4" Background="#1B1452" BorderBrush="#302A76" BorderThickness="2" ClipToBounds="True">
              <Image Source="assets/swai-key.png" Stretch="UniformToFill" />
            </Border>
            <TextBlock x:Name="TitleBarText" Text="Swai Key 键盘连点器" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
            <Button Style="{StaticResource TitleButton}" Click="MinimizeButton_Click">
              <Path Width="16" Height="3" Stretch="Fill" Fill="{StaticResource TextPrimary}" Data="M0,0 L18,0 L18,4 L0,4 Z" />
            </Button>
            <Button Margin="8,0,0,0" Style="{StaticResource TitleButton}" Background="#D8424D" Click="CloseButton_Click">
              <Grid Width="18" Height="18">
                <Path Stroke="White" StrokeThickness="4" StrokeStartLineCap="Square" StrokeEndLineCap="Square" Data="M3,3 L15,15" />
                <Path Stroke="White" StrokeThickness="4" StrokeStartLineCap="Square" StrokeEndLineCap="Square" Data="M15,3 L3,15" />
              </Grid>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="1" Margin="16,12,16,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="136" />
          <RowDefinition Height="166" />
          <RowDefinition Height="90" />
          <RowDefinition Height="56" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="8" BorderBrush="#25245F" BorderThickness="2" ClipToBounds="True">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#070B18" Offset="0" />
              <GradientStop Color="#0A1024" Offset="0.55" />
              <GradientStop Color="#11162A" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <Grid>
            <Grid.Triggers>
              <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                  <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetName="ReadyGlow" Storyboard.TargetProperty="Opacity" From="0.25" To="0.95" Duration="0:0:1.45" />
                    <DoubleAnimation Storyboard.TargetName="ReadyDot" Storyboard.TargetProperty="Opacity" From="0.82" To="1" Duration="0:0:1.45" />
                    <DoubleAnimation Storyboard.TargetName="ReadyText" Storyboard.TargetProperty="Opacity" From="0.7" To="1" Duration="0:0:1.45" />
                    <DoubleAnimation Storyboard.TargetName="ReadyPulse" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.86" To="1.16" Duration="0:0:1.45" />
                    <DoubleAnimation Storyboard.TargetName="ReadyPulse" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.86" To="1.16" Duration="0:0:1.45" />
                    <DoubleAnimation Storyboard.TargetName="KeyGlow" Storyboard.TargetProperty="Opacity" From="0.45" To="0.75" Duration="0:0:1.65" />
                    <DoubleAnimation Storyboard.TargetName="KeyFloat" Storyboard.TargetProperty="Y" From="0" To="-3" Duration="0:0:1.8" />
                  </Storyboard>
                </BeginStoryboard>
              </EventTrigger>
            </Grid.Triggers>

            <Ellipse Width="166" Height="98" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,8,-36,0" Opacity="0.16">
              <Ellipse.Fill>
                <RadialGradientBrush>
                  <GradientStop Color="#22D3EE" Offset="0" />
                  <GradientStop Color="#7C3AED" Offset="0.42" />
                  <GradientStop Color="#001020" Offset="1" />
                </RadialGradientBrush>
              </Ellipse.Fill>
            </Ellipse>

            <Canvas Opacity="0.12" IsHitTestVisible="False">
              <Rectangle Width="2" Height="132" Fill="#3951C9" Canvas.Left="20" Canvas.Top="0" />
              <Rectangle Width="2" Height="132" Fill="#3951C9" Canvas.Left="60" Canvas.Top="0" />
              <Rectangle Width="2" Height="132" Fill="#3951C9" Canvas.Left="100" Canvas.Top="0" />
              <Rectangle Width="2" Height="132" Fill="#3951C9" Canvas.Left="140" Canvas.Top="0" />
              <Rectangle Width="2" Height="132" Fill="#3951C9" Canvas.Left="180" Canvas.Top="0" />
              <Rectangle Width="398" Height="1" Fill="#28306C" Canvas.Left="0" Canvas.Top="34" />
              <Rectangle Width="398" Height="1" Fill="#28306C" Canvas.Left="0" Canvas.Top="72" />
              <Rectangle Width="398" Height="1" Fill="#28306C" Canvas.Left="0" Canvas.Top="110" />
            </Canvas>

            <Grid Margin="16,10,12,10">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="116" />
              </Grid.ColumnDefinitions>

              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="SMALL · FAST · CLEAN" Foreground="#5B7CFF" FontFamily="Consolas" FontSize="11" FontWeight="Bold" />
                <TextBlock x:Name="HeroSubtitleText" Text="小体积、无广告。F7 启动或停止。" Margin="0,7,0,0" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" MaxWidth="220" LineHeight="15" />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                  <Grid x:Name="ReadyPulse" Width="17" Height="17" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                      <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Grid.RenderTransform>
                    <Ellipse x:Name="ReadyGlow" Fill="#A3E635" Opacity="0.55">
                      <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.95" Color="#A3E635" />
                      </Ellipse.Effect>
                    </Ellipse>
                    <Ellipse x:Name="ReadyDot" Width="9" Height="9" Fill="#A3E635" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <TextBlock x:Name="ReadyText" Text="READY" Margin="8,0,0,0" Foreground="#22F3B4" FontFamily="Consolas" FontSize="16" FontWeight="Bold" VerticalAlignment="Center">
                    <TextBlock.Effect>
                      <DropShadowEffect BlurRadius="9" ShadowDepth="0" Opacity="0.78" Color="#22F3B4" />
                    </TextBlock.Effect>
                  </TextBlock>
                  <TextBlock Text=" : :" Margin="12,0,0,0" Foreground="{StaticResource Cyan}" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Opacity="0.8" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="v1.0.0" Margin="0,7,0,0" Foreground="#5B7CFF" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Opacity="0.9" />
              </StackPanel>

              <Viewbox Grid.Column="1" Width="108" Height="88" HorizontalAlignment="Right" VerticalAlignment="Center" Stretch="Uniform">
              <Viewbox.RenderTransform>
                <TranslateTransform x:Name="KeyFloat" Y="0" />
              </Viewbox.RenderTransform>
              <Canvas Width="150" Height="122" ClipToBounds="False">
                <Ellipse x:Name="KeyGlow" Width="112" Height="28" Canvas.Left="24" Canvas.Top="92" Fill="#22D3EE" Opacity="0.58">
                  <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.92" Color="#22D3EE" />
                  </Ellipse.Effect>
                </Ellipse>
                <Polygon Points="28,92 122,92 138,105 12,105" Fill="#111735" Stroke="#22D3EE" StrokeThickness="2" Opacity="0.9" />
                <Polygon Points="38,30 116,43 130,82 54,96 22,68" Stroke="#EC4899" StrokeThickness="2">
                  <Polygon.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                      <GradientStop Color="#241263" Offset="0" />
                      <GradientStop Color="#7C3AED" Offset="0.55" />
                      <GradientStop Color="#1B1E7A" Offset="1" />
                    </LinearGradientBrush>
                  </Polygon.Fill>
                </Polygon>
                <Polygon Points="54,96 130,82 119,101 42,112 22,68" Fill="#17135D" Stroke="#7C3AED" StrokeThickness="2" />
                <Polygon Points="116,43 130,82 119,101 102,61" Fill="#32118A" Stroke="#EC4899" StrokeThickness="2" />
                <Polygon Points="38,30 116,43 102,61 50,52 22,68" Stroke="#A855F7" StrokeThickness="2">
                  <Polygon.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                      <GradientStop Color="#B635F6" Offset="0" />
                      <GradientStop Color="#7C3AED" Offset="0.52" />
                      <GradientStop Color="#3922AE" Offset="1" />
                    </LinearGradientBrush>
                  </Polygon.Fill>
                </Polygon>
                <Path Data="M53,38 L109,48" Stroke="#F0ABFC" StrokeThickness="3" Opacity="0.85" />
                <Path Data="M48,101 L118,91" Stroke="#22D3EE" StrokeThickness="4" Opacity="0.95" />
                <Path Data="M116,84 L126,80 L118,99" Stroke="#EC4899" StrokeThickness="3" Opacity="0.95" />
                <TextBlock Text="F7" Canvas.Left="58" Canvas.Top="45" Foreground="White" FontSize="30" FontWeight="Black" RenderTransformOrigin="0.5,0.5">
                  <TextBlock.RenderTransform>
                    <RotateTransform Angle="11" />
                  </TextBlock.RenderTransform>
                  <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="0" Opacity="0.65" Color="#FFFFFF" />
                  </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="+" Canvas.Left="16" Canvas.Top="14" Foreground="{StaticResource Cyan}" FontSize="17" FontWeight="Black" />
                <TextBlock Text="+" Canvas.Left="126" Canvas.Top="58" Foreground="{StaticResource Pink}" FontSize="18" FontWeight="Black" />
                <TextBlock Text="+" Canvas.Left="102" Canvas.Top="10" Foreground="{StaticResource Yellow}" FontSize="15" FontWeight="Black" />
                <Rectangle Width="7" Height="7" Canvas.Left="22" Canvas.Top="44" Fill="{StaticResource Cyan}" />
                <Rectangle Width="6" Height="6" Canvas.Left="132" Canvas.Top="26" Fill="{StaticResource Pink}" />
                <Rectangle Width="4" Height="4" Canvas.Left="114" Canvas.Top="20" Fill="{StaticResource Purple}" Opacity="0.7" />
                <Ellipse Width="4" Height="4" Canvas.Left="8" Canvas.Top="74" Fill="#5B7CFF" />
              </Canvas>
              </Viewbox>
            </Grid>
          </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,12,0,0" Padding="14,8" CornerRadius="8" Background="{StaticResource CardGradient}" BorderBrush="{StaticResource StrokeHot}" BorderThickness="2">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="43" />
              <RowDefinition Height="2" />
              <RowDefinition Height="44" />
              <RowDefinition Height="2" />
              <RowDefinition Height="45" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="138" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Border Style="{StaticResource IconCell}" Background="#3B82F6">
                <UniformGrid Rows="3" Columns="3" Margin="6">
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                  <Rectangle Fill="#081129" Margin="1" />
                </UniformGrid>
              </Border>
              <TextBlock x:Name="KeyLabel" Text="连点键位" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="Bold" />
            </StackPanel>
            <TextBox x:Name="KeyBox" Grid.Column="1" Text="Space" TextAlignment="Center" IsReadOnly="True" Style="{StaticResource PixelTextBox}" PreviewKeyDown="KeyBox_PreviewKeyDown" />

            <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#1F2354" Margin="0,0,0,0" />

            <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
              <Border Style="{StaticResource IconCell}" Background="#5AE136">
                <Grid Margin="5">
                  <Rectangle Width="6" Height="6" Fill="#101633" HorizontalAlignment="Center" VerticalAlignment="Top" />
                  <Rectangle Width="6" Height="6" Fill="#101633" HorizontalAlignment="Left" VerticalAlignment="Bottom" />
                  <Rectangle Width="6" Height="6" Fill="#101633" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
                </Grid>
              </Border>
              <TextBlock x:Name="ModifiersLabel" Text="组合按键" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="Bold" />
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
              <CheckBox x:Name="CtrlBox" Content="Ctrl" Margin="0,0,10,0" Style="{StaticResource SwaiCheckBox}" />
              <CheckBox x:Name="ShiftBox" Content="Shift" Margin="0,0,10,0" Style="{StaticResource SwaiCheckBox}" />
              <CheckBox x:Name="AltBox" Content="Alt" Style="{StaticResource SwaiCheckBox}" />
            </StackPanel>

            <Border Grid.Row="3" Grid.ColumnSpan="2" Background="#1F2354" />

            <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center">
              <Border Style="{StaticResource IconCell}" Background="#EC4899">
                <Grid>
                  <Ellipse Stroke="#101633" StrokeThickness="3" Margin="5" />
                  <Rectangle Width="3" Height="8" Fill="#101633" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0" />
                </Grid>
              </Border>
              <TextBlock x:Name="IntervalLabel" Text="按键间隔" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="Bold" />
            </StackPanel>
            <Grid Grid.Row="4" Grid.Column="1" VerticalAlignment="Center">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="38" />
              </Grid.ColumnDefinitions>
              <TextBox x:Name="IntervalBox" Text="100" TextAlignment="Center" VerticalAlignment="Center" Style="{StaticResource PixelTextBox}" PreviewTextInput="IntervalBox_PreviewTextInput" LostFocus="IntervalBox_LostFocus" KeyDown="IntervalBox_KeyDown" />
              <TextBlock Grid.Column="1" Text="ms" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Purple}" FontSize="15" FontWeight="Bold" />
            </Grid>
          </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Padding="14,8" CornerRadius="8" Background="{StaticResource CardGradient}" BorderBrush="{StaticResource StrokeHot}" BorderThickness="2">
            <StackPanel>
              <TextBlock x:Name="StatusLabel" Text="状态" Foreground="{StaticResource Purple}" FontSize="14" FontWeight="Bold" />
              <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="♥" Foreground="{StaticResource Pink}" FontSize="17" FontWeight="Black" VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText" Text="已停止" Margin="10,0,0,0" Foreground="{StaticResource Cyan}" FontSize="18" FontWeight="Black" VerticalAlignment="Center" />
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Grid.Column="2" Padding="14,8" CornerRadius="8" Background="{StaticResource CardGradient}" BorderBrush="{StaticResource StrokeHot}" BorderThickness="2">
            <StackPanel>
              <TextBlock x:Name="CountLabel" Text="按键次数" Foreground="{StaticResource Purple}" FontSize="14" FontWeight="Bold" />
              <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="★" Foreground="{StaticResource Yellow}" FontSize="17" FontWeight="Black" VerticalAlignment="Center" />
                <TextBlock x:Name="CountText" Text="0" Margin="10,0,0,0" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Black" VerticalAlignment="Center" />
                <TextBlock x:Name="CountUnitText" Text="次" Margin="10,0,0,2" Foreground="{StaticResource TextPrimary}" FontSize="13" VerticalAlignment="Center" />
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>

        <Button x:Name="ToggleButton" Grid.Row="3" Margin="4,6,4,0" VerticalAlignment="Top" Content=">> 开始 F7" Style="{StaticResource PrimaryButton}" Click="ToggleButton_Click" />

        <Grid Grid.Row="4" Margin="0,0,0,0">
          <Border Height="40" VerticalAlignment="Bottom" Margin="0,0,0,8" CornerRadius="8" Background="#111735" BorderBrush="{StaticResource Stroke}" BorderThickness="2">
            <Grid>
              <CheckBox x:Name="TopmostBox" Margin="16,0,0,0" Content="窗口置顶" VerticalAlignment="Center" HorizontalAlignment="Left" Style="{StaticResource SwaiCheckBox}" Checked="TopmostBox_Changed" Unchecked="TopmostBox_Changed" />
            </Grid>
          </Border>
        </Grid>
      </Grid>

      <Border Grid.Row="2" Background="#0A0E23" BorderBrush="#202557" BorderThickness="0,2,0,0">
        <TextBlock x:Name="FooterText" Text="♥  Designed by Hongswai · 中文  ♥" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Purple}" FontSize="13" FontWeight="Bold" Cursor="Hand" MouseLeftButtonUp="FooterText_MouseLeftButtonUp" />
      </Border>
    </Grid>
  </Border>
</Window>

