<Window x:Class="WpfKeyAutoClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="键盘连点器"
        Width="390"
        Height="560"
        MinWidth="390"
        MinHeight="560"
        MaxWidth="390"
        MaxHeight="560"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Icon="assets/icon.ico"
        Background="Transparent"
        FontFamily="Open Sans, Source Han Serif SC">
  <Window.Resources>
    <SolidColorBrush x:Key="AccentBrush" Color="#00A7C8" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#0093B2" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#007D99" />
    <SolidColorBrush x:Key="TextPrimary" Color="#EAF4F7" />
    <SolidColorBrush x:Key="TextSecondary" Color="#91A4AD" />
    <SolidColorBrush x:Key="LineBrush" Color="#263741" />
    <SolidColorBrush x:Key="WindowBrush" Color="#111B22" />
    <SolidColorBrush x:Key="FieldBrush" Color="#18252D" />
    <SolidColorBrush x:Key="ControlBrush" Color="#1E303A" />

    <Style x:Key="TitleButton" TargetType="{x:Type Button}">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="30" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="Root" CornerRadius="15" Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#223844" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#294450" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="{x:Type Button}">
      <Setter Property="Height" Value="48" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="#061218" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="Root" CornerRadius="24" Background="{StaticResource AccentBrush}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentHoverBrush}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentPressedBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="TechCheckBox" TargetType="{x:Type CheckBox}">
      <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type CheckBox}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Border x:Name="Box"
                      Width="20"
                      Height="20"
                      CornerRadius="6"
                      Background="{StaticResource FieldBrush}"
                      BorderBrush="#2C4350"
                      BorderThickness="1">
                <Path x:Name="Tick"
                      Data="M4,10 L8,14 L16,6"
                      Stroke="#061218"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Visibility="Collapsed" />
              </Border>
              <ContentPresenter Margin="9,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter TargetName="Tick" Property="Visibility" Value="Visible" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border Margin="10" CornerRadius="24" Background="{StaticResource WindowBrush}" BorderBrush="#27404C" BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.22" Color="#000000" />
    </Border.Effect>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="52" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Background="Transparent" PreviewMouseLeftButtonDown="TitleBar_PreviewMouseLeftButtonDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
          <Border Width="24" Height="24" CornerRadius="8" Background="#1B2B34">
            <Ellipse Width="9" Height="9" Fill="#7C5CFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="键盘连点器" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
          <Button Style="{StaticResource TitleButton}" Click="MinimizeButton_Click">
            <Path Width="13" Height="2" Stretch="Fill" Fill="#91A4AD" Data="M0,0 L13,0 L13,2 L0,2 Z" />
          </Button>
          <Button Margin="2,0,0,0" Style="{StaticResource TitleButton}" Click="CloseButton_Click">
            <Grid Width="13" Height="13">
              <Path Stroke="#91A4AD" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M1,1 L12,12" />
              <Path Stroke="#91A4AD" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M12,1 L1,12" />
            </Grid>
          </Button>
        </StackPanel>
      </Grid>

      <Grid Grid.Row="1" Margin="28,14,28,28">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,28">
          <TextBlock Text="自动按键" Foreground="{StaticResource TextPrimary}" FontSize="34" FontWeight="Bold" />
          <TextBlock Text="点键位框后按目标键，F7 启动或停止。" Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" FontSize="13" />
        </StackPanel>

        <Grid Grid.Row="1">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="90" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="连点键位" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold" />
            <TextBox x:Name="KeyBox" Grid.Column="1" Height="44" Text="Space" Padding="14,0" VerticalContentAlignment="Center" TextAlignment="Center" IsReadOnly="True" Foreground="{StaticResource TextPrimary}" Background="{StaticResource FieldBrush}" BorderBrush="#2C4350" BorderThickness="1" FontSize="15" PreviewKeyDown="KeyBox_PreviewKeyDown" />
          </Grid>

          <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="90" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="组合按键" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" MinHeight="24" VerticalAlignment="Center">
              <CheckBox x:Name="CtrlBox" Content="Ctrl" Margin="0,0,20,0" Style="{StaticResource TechCheckBox}" />
              <CheckBox x:Name="ShiftBox" Content="Shift" Margin="0,0,20,0" Style="{StaticResource TechCheckBox}" />
              <CheckBox x:Name="AltBox" Content="Alt" Style="{StaticResource TechCheckBox}" />
            </StackPanel>
          </Grid>

          <Border Grid.Row="4" Height="1" Background="{StaticResource LineBrush}" />

          <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="90" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="34" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="按键间隔" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold" />
            <TextBox x:Name="IntervalBox" Grid.Column="1" Height="44" Text="100" Padding="14,0" VerticalContentAlignment="Center" Foreground="{StaticResource TextPrimary}" Background="{StaticResource FieldBrush}" BorderBrush="#2C4350" BorderThickness="1" FontSize="15" />
            <TextBlock Grid.Column="2" Text="ms" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{StaticResource TextSecondary}" FontSize="13" />
          </Grid>
        </Grid>

        <Grid Grid.Row="2" VerticalAlignment="Center">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock Text="状态" Foreground="{StaticResource TextSecondary}" FontSize="12" />
            <TextBlock x:Name="StatusText" Text="已停止" Margin="0,6,0,0" Foreground="{StaticResource TextPrimary}" FontSize="25" FontWeight="Bold" />
          </StackPanel>
          <StackPanel Grid.Column="1">
            <TextBlock Text="按键次数" Foreground="{StaticResource TextSecondary}" FontSize="12" />
            <TextBlock x:Name="CountText" Text="0" Margin="0,6,0,0" Foreground="{StaticResource TextPrimary}" FontSize="25" FontWeight="Bold" />
          </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3">
          <Button x:Name="ToggleButton" Content="开始 F7" Style="{StaticResource PrimaryButton}" Click="ToggleButton_Click" />
          <CheckBox x:Name="TopmostBox" Margin="2,16,0,0" Content="窗口置顶" Style="{StaticResource TechCheckBox}" Checked="TopmostBox_Changed" Unchecked="TopmostBox_Changed" />
          <TextBlock Text="© 2026 Hongwai" Margin="2,14,0,0" Foreground="{StaticResource TextSecondary}" FontSize="11" Opacity="0.72" />
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
